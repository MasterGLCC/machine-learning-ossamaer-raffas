
import numpy as np  # Importation de NumPy pour les calculs numériques et les tableaux


from collections import Counter  # Importation de Counter pour compter les occurrences et faire le vote majoritaire

class KNN:
    
    def __init__(self, k=3): # constrecteur
        self.k = k                    # Nombre de voisins à considérer
        self.X_train = None           # Stockera les données d'entraînement 
        self.y_train = None           # Stockera les étiquettes d'entraînement 


    def fit(self, X, y):

        self.X_train = X              # Stocke les caractéristiques (coordonnées) des points
        self.y_train = y              # Stocke les classes correspondantes (0 ou 1)
        
    # fonction pour prédire les classes de plusieurs échantillons
    def predict(self, X):

        predictions = [self._predict_one(x) for x in X]
        
        # Convertit la liste en tableau numpy et la retourne
        return np.array(predictions)
    
    def _predict_one(self, x):
        
        
        # Étape 1: Calcul des distances euclidiennes entre x et tous les points d'entraînement
        # Formule: √[(x₁-x₁')² + (x₂-x₂')² + ...]
        # np.sqrt() : racine carrée
        # np.sum() : somme des carrés des différences
        # (x - x_train)**2 : élève au carré chaque différence

        distances = [np.sqrt(np.sum((x - x_train)**2)) for x_train in self.X_train]
        
        # Étape 2: Trouver les indices des k plus proches voisins
        # np.argsort() : trie les distances et retourne les indices dans l'ordre croissant
        # [:self.k] : prend les k premiers indices (les plus petites distances)

        k_indices = np.argsort(distances)[:self.k]
        
        # Étape 3: Récupérer les étiquettes (classes) des k plus proches voisins
        # Pour chaque indice, prend la classe correspondante dans y_train

        k_nearest_labels = [self.y_train[i] for i in k_indices]
        
        # Counter() : crée un dictionnaire {classe: nombre d'occurrences}
    
        # .most_common(1) : retourne la classe la plus fréquente sous forme de liste


        most_common = Counter(k_nearest_labels).most_common(1)
        
       
        return most_common[0][0]   # # Retourne la classe gagnante (le premier élément du tuple)
 



X = np.array([[1, 2],   # Point 0 
              [2, 3],   # Point 1
              [3, 4],   
              [8, 9],   
              [9, 10]]) 

# y : étiquettes(0 ou 1)
y = np.array([0, 0, 0, 1, 1])  

# Création d'une instance du modèle KNN avec k=3 (3 voisins)
knn = KNN(k=3)

# Entraînement du modèle (stockage des données)
knn.fit(X, y)

# Prédiction pour un nouveau point [2.5, 3.5]
prediction = knn.predict([[2.5, 3.5]])

# Affichage du résultat
print(knn.predict([[2.5, 3.5]]))  # Affiche la classe prédite (devrait être 0)
