
import numpy as np  # Bibliothèque pour les calculs numériques et les tableaux
import matplotlib.pyplot as plt  # Bibliothèque pour les graphiques 2D
import pandas as pd


class PolynomialRegression:
    
    def __init__(self, degree=2):
        self.degree = degree      # degré du polynôme
        self.theta = None         # coefficients du modèle
        self.y_pred = None        # prédictions

    def transform(self, X):
        # Crée la matrice polynomiale

        X_poly = np.ones((X.shape[0], 1))
        # colonne de 1 pour β0 (intercept)

        for i in range(1, self.degree + 1):
            X_poly = np.c_[X_poly, X ** i]
            # ajoute X^1, X^2, X^3, ...

        return X_poly

    def fit(self, X, y):
        X_poly = self.transform(X)
        # transformation des données

        # formule normale : θ = (XᵀX)^(-1) Xᵀy
        self.theta = np.linalg.inv(X_poly.T.dot(X_poly)).dot(X_poly.T).dot(y)

        # prédictions sur données d'entraînement
        self.y_pred = X_poly.dot(self.theta)

    def predict(self, X):
        X_poly = self.transform(X)
        # transforme les nouvelles données

        return X_poly.dot(self.theta)
        # retourne les prédictions


data = pd.read_csv('Data1.csv')

X = data[['YearsExperience']].values
# variable indépendante

y = data['Salary'].values
# variable cible





model = PolynomialRegression(degree=3)
# modèle polynomial degré 3

model.fit(X, y)
# entraînement


y_pred = model.predict(X)


plt.scatter(X, y, color='blue', label='Data')
# points réels

# tri pour courbe propre
sorted_index = X.flatten().argsort()

plt.plot(X[sorted_index], y_pred[sorted_index], color='red', label='Polynomial Regression')
# courbe polynomiale

plt.xlabel('YearsExperience')
# axe X

plt.ylabel('Salary')
# axe Y

plt.title('Polynomial Regression (Class Implementation)')
# titre

plt.legend()
# légende

plt.show()
# affichage
