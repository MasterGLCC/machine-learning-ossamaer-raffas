import numpy as np
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D
import pandas as pd


class SVM:
    
    def __init__(self, lr=0.001, lambda_param=0.01, n_iters=1000):
        self.lr = lr                    # taux d'apprentissage
        self.lambda_param = lambda_param  # régularisation
        self.n_iters = n_iters          # nombre d'itérations
        self.w = None                   # coefficients (poids)
        self.b = None                   # biais (intercept)
        self.loss_history_ = []         # historique de la perte

    def fit(self, X, y):
        n_samples, n_features = X.shape
        
        # Convertir y en -1 et 1 (SVM utilise -1/1 au lieu de 0/1)
        y_ = np.where(y <= 0, -1, 1)
        
        # Initialisation des paramètres
        self.w = np.zeros(n_features)
        self.b = 0
        
        # Descente de gradient
        for _ in range(self.n_iters):
            for idx, x_i in enumerate(X):
                # Vérifie la condition de marge: y_i * (w·x_i - b) >= 1
                condition = y_[idx] * (np.dot(x_i, self.w) - self.b) >= 1
                
                if condition:
                    # Mise à jour uniquement de la régularisation
                    self.w -= self.lr * (2 * self.lambda_param * self.w)
                else:
                    # Mise à jour complète avec la perte hinge
                    self.w -= self.lr * (2 * self.lambda_param * self.w - np.dot(x_i, y_[idx]))
                    self.b -= self.lr * y_[idx]
        
        # Calcul des prédictions 
        y_pred = self.predict(X)
        self.accuracy_ = np.mean(y_pred == y_)

    def predict(self, X):
        # Calcule w·X - b
        approx = np.dot(X, self.w) - self.b
        # Retourne 1 si positif, -1 si négatif
        return np.sign(approx)





data = pd.read_csv('Data1.csv')

# Caractéristiques: YearsExperience et Age
X = data[['YearsExperience', 'age']].values

# Pour SVM, on doit avoir des classes 0/1
# On crée une classe basée sur le salaire (ex: salaire > médiane = 1, sinon 0)
median_salary = np.median(data['Salary'])
y = (data['Salary'] > median_salary).astype(int)  # 0 ou 1

plt.scatter(data['YearsExperience'], data['age'], c=y, cmap='coolwarm', s=50)
plt.xlabel('YearsExperience')
plt.ylabel('Age')
plt.title("Données SVM - Couleur = Classe (salaire > médiane)")
plt.colorbar(label='Classe (0=bas, 1=haut)')
plt.show()



svm = SVM(lr=0.001, lambda_param=0.01, n_iters=500)
svm.fit(X, y)

# Affichage résultats
print(f"Poids (w): {svm.w}")
print(f"Biais (b): {svm.b:.4f}")
print(f"Précision: {svm.accuracy_:.2%}")


fig = plt.figure(figsize=(12, 8))
ax = fig.add_subplot(111, projection='3d')

# Nuage de points 3D
ax.scatter(X[:,0], X[:,1], y, c=y, cmap='coolwarm', s=50, label='Données')

# Création d'une grille pour l'hyperplan de décision
x1_range = np.linspace(X[:,0].min(), X[:,0].max(), 20)
x2_range = np.linspace(X[:,1].min(), X[:,1].max(), 20)
x1_grid, x2_grid = np.meshgrid(x1_range, x2_range)

# Calcul de la fonction de décision: w·X - b
Z_grid = svm.w[0] * x1_grid + svm.w[1] * x2_grid - svm.b

# Tracé de l'hyperplan de décision (là où Z = 0)
ax.plot_surface(x1_grid, x2_grid, Z_grid, alpha=0.3, color='green')

# Tracé du plan à Z=0 (frontière de décision)
ax.contour(x1_grid, x2_grid, Z_grid, levels=[0], colors='black', linewidths=2)

ax.set_xlabel('YearsExperience')
ax.set_ylabel('Age')
ax.set_zlabel('Classe (0 ou 1)')
ax.set_title("SVM - Frontière de décision (hyperplan séparateur)")

plt.show()



plt.figure(figsize=(10, 8))

# Nuage de points
plt.scatter(X[:,0], X[:,1], c=y, cmap='coolwarm', s=50, edgecolors='black')

# Grille pour la frontière
x_min, x_max = X[:,0].min() - 0.5, X[:,0].max() + 0.5
y_min, y_max = X[:,1].min() - 0.5, X[:,1].max() + 0.5
xx, yy = np.meshgrid(np.linspace(x_min, x_max, 100), np.linspace(y_min, y_max, 100))

# Prédiction sur la grille
Z = svm.predict(np.c_[xx.ravel(), yy.ravel()])
Z = Z.reshape(xx.shape)

# Tracé de la frontière
plt.contourf(xx, yy, Z, alpha=0.3, cmap='coolwarm')
plt.contour(xx, yy, Z, levels=[0], colors='black', linewidths=2)

plt.xlabel('YearsExperience')
plt.ylabel('Age')
plt.title(f"SVM - Frontière de décision\nPrécision: {svm.accuracy_:.2%}")
plt.colorbar(label='Classe')
plt.grid(True, alpha=0.3)
plt.show()
