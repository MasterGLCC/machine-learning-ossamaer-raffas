class SimpleLinearRegression:
    
    def __init__(self):
        self.coefficients_ = None   # 
        self.r2score_ = None        # score R²
        self.y_pred = None          # prédictions
    
    def fit(self, X, y):
        # Nombre de donner
        n = X.shape[0]
        
        # Ajouter une colonne de 1 pour le biais (intercept)
        X_b = np.c_[np.ones((n, 1)), X]
        
        # Calcul des coefficients avec la formule normale :
        # θ = (XᵀX)^(-1) Xᵀy
        self.coefficients_ = np.linalg.inv(X_b.T.dot(X_b)).dot(X_b.T).dot(y)
        
        # Faire les prédictions sur X
        y_pred = X_b.dot(self.coefficients_)
        self.y_pred = y_pred
        
        # Calcul du R²
        ss_total = np.sum((y - np.mean(y))**2)
        ss_res = np.sum((y - y_pred)**2)
        
        if ss_total == 0:
            self.r2score_ = 1 if ss_res == 0 else 0
        else:
            self.r2score_ = 1 - (ss_res / ss_total)
    
    def predict(self, X):
        # Nombre de donner
        n = X.shape[0]
        
        # Ajouter colonne de 1
        X_b = np.c_[np.ones((n, 1)), X]
        
        # Prédiction
        return X_b.dot(self.coefficients_)






slr=SimpleLinearRegression()  #  Crée un  modèle de type SimpleLinearRegression
slr.fit(X,y)   #    Entraîne le modèle sur les données X (entrées) et y (sorties)




print("simple lr coefficients:",slr.coefficients_)  # Affiche les coefficients du modèle (intercept et pente)
print("R2 Score:",slr.r2score_)    # Affiche le score R² qui mesure la qualité de l'ajustement du modèle
#Très bon ajustement (proche de 1 = parfait).










